<h1>Task Calendar</h1>

<div id="calendar">
  <!-- Calendar implementation using JavaScript will go here -->
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Example: Initialize a simple calendar
    const calendarElement = document.getElementById("calendar");
    calendarElement.innerHTML = "<p>Calendar will be displayed here</p>";
  });
</script>

<%= link_to 'New Task', new_task_path, class: 'btn btn-primary' %>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Category</th>
      <th>Start Date</th>
      <th>End Date</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @tasks.each do |task| %>
      <tr>
        <td><%= task.name %></td>
        <td><%= task.category %></td>
        <td><%= task.date_from %></td>
        <td><%= task.date_to %></td>
        <td>
          <%= link_to 'Show', task_path(task) %>
          <%= link_to 'Edit', edit_task_path(task) %>
          <%= link_to 'Delete', task_path(task), method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
