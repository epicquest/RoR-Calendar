<div class="page-header">
  <h1>Edit Task</h1>
  <p class="text-light">Update your task details</p>
</div>

<%= form_with(model: @task, local: true, html: { class: 'form-container' }) do |form| %>
  <% if @task.errors.any? %>
    <div class="error-container">
      <svg class="w-6 h-6 text-error" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <h2><%= pluralize(@task.errors.count, "error") %> prohibited this task from being saved:</h2>
      <ul>
        <% @task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :name, class: 'form-label' %>
    <%= form.text_field :name, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :category, class: 'form-label' %>
    <%= form.text_field :category, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :date_from, class: 'form-label' %>
    <%= form.datetime_select :date_from, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :date_to, class: 'form-label' %>
    <%= form.datetime_select :date_to, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :description, class: 'form-label' %>
    <%= form.text_area :description, class: 'form-control' %>
  </div>

  <div class="actions">
    <%= form.submit 'Update Task', class: 'btn btn-primary' %>
  </div>
<% end %>

<%= link_to 'Back', tasks_path, class: 'btn btn-secondary' %>
